{
    "observation.images.camera_head": {
        "dtype": "video",
        "shape": [360, 640, 3],
        "names": ["height", "width", "channel"],
        "video_info": {
            "video.fps": 30.0,
            "video.codec": "libx264",
            "video.pix_fmt": "yuv420p",
            "video.is_depth_map": false,
            "has_audio": false
        }
    },
    "observation.state": {
        "dtype": "float32",
        "shape": [19]
    },
    "action": {
        "dtype": "float32",
        "shape": [19]
    },
    "episode_index": {
        "dtype": "int64",
        "shape": [1],
        "names": null
    },
    "frame_index": {
        "dtype": "int64",
        "shape": [1],
        "names": null
    },
    "index": {
        "dtype": "int64",
        "shape": [1],
        "names": null
    },
    "task_index": {
        "dtype": "int64",
        "shape": [1],
        "names": null
    },
    "hdf5_mapping": {
        "observation.state": [
            "observation/joint_state/position/data",
            {
                "hdf5_key": "observation/grip_left_position/data",
                "expand_dims": true
            },
            {
                "hdf5_key": "observation/grip_right_position/data",
                "expand_dims": true
            }
        ],
        "action": [
            "action/joint_state/position/data",
            {
                "hdf5_key": "action/grip_left_position/data",
                "expand_dims": true
            },
            {
                "hdf5_key": "action/grip_right_position/data",
                "expand_dims": true
            }
        ],
        "observation.images.camera_head": {
            "hdf5_key": "camera_observations/color_images/camera_head",
            "encoding": "jpeg",
            "image_size": [640, 360]
        }
    }
}
