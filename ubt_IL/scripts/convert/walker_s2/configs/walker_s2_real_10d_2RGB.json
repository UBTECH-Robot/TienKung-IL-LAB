          "head_yaw_joint"
        ]
      },
      {
        "hdf5_key": "metadata/motion_data/ecat_right_grip_state/json_list",
        "extract": "field",
        "field": "pos",
        "expand_dims": true
      }
    ],
    "action": [
      {
        "hdf5_key": "metadata/motion_data/mc_joint_states/json_list",
        "extract": "position_by_name",
        "names": [
          "R_elbow_roll_joint",
          "R_elbow_yaw_joint",
          "R_shoulder_pitch_joint",
          "R_shoulder_roll_joint",
          "R_shoulder_yaw_joint",
