          "R_wrist_roll_joint",
          "head_pitch_joint",
          "head_yaw_joint"
        ]
      },
      {
        "hdf5_key": "metadata/motion_data/ecat_right_grip_cmd/json_list",
        "extract": "field",
        "field": "pos",
        "expand_dims": true
      }
    ],
    "observation.images.camera_head_right": {
      "hdf5_key": "metadata/image_data/sensor_camera_stereo_right_image_raw/value_list",
