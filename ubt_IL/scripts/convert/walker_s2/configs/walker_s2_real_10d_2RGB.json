      "image_size": [320, 256]
    },
    "observation.images.camera_wrist_right": {
      "hdf5_key": "metadata/image_data/sensor_camera_wrist_right_color_raw/value_list",
      "encoding": "mp4_value_list",
      "image_size": [320, 240]
    }
  }
