{
    "dataset": {
        "repo_id": "Walker_S2_real_10d_1RGBD",
        "root": "/ubt_IL/dataset/Walker_S2_real_10d_1RGBD",
        "episodes": null,
        "image_transforms": {
            "enable": false,
            "max_num_transforms": 3,
            "random_order": false,
            "tfs": {
                "brightness": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": {
                        "brightness": [
                            0.8,
                            1.2
                        ]
                    }
                },
                "contrast": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": {
                        "contrast": [
                            0.8,
                            1.2
                        ]
                    }
                },
                "saturation": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": {
                        "saturation": [
                            0.5,
                            1.5
                        ]
                    }
                },
                "hue": {
                    "weight": 1.0,
                    "type": "ColorJitter",
                    "kwargs": {
                        "hue": [
                            -0.05,
                            0.05
                        ]
                    }
                },
                "sharpness": {
                    "weight": 1.0,
                    "type": "SharpnessJitter",
                    "kwargs": {
                        "sharpness": [
                            0.5,
                            1.5
                        ]
                    }
                },
                "affine": {
                    "weight": 1.0,
                    "type": "RandomAffine",
                    "kwargs": {
                        "degrees": [
                            -5.0,
                            5.0
                        ],
                        "translate": [
                            0.05,
                            0.05
                        ]
                    }
                }
            }
        },
        "revision": null,
        "use_imagenet_stats": false,
        "video_backend": "torchcodec",
        "return_uint8": false,
        "streaming": false
    },
    "env": null,
    "policy": {
        "type": "pi05",

        "paligemma_variant": "gemma_2b",
        "action_expert_variant": "gemma_300m",
        "dtype": "bfloat16",

        "n_obs_steps": 1,
        "chunk_size": 50,
        "n_action_steps": 50,

        "max_state_dim": 32,
        "max_action_dim": 32,

        "input_features": {
            "observation.images.camera_head": {
                "type": "VISUAL",
                "shape": [
                    3,
                    360,
                    640
                ]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [
                    10
                ]
            }
        },
        "output_features": {
            "action": {
                "type": "ACTION",
                "shape": [
                    10
                ]
            }
        },

        "image_resolution": [
            224,
            224
        ],

        "normalization_mapping": {
            "VISUAL": "IDENTITY",
            "STATE": "QUANTILES",
            "ACTION": "QUANTILES"
        },

        "use_relative_actions": false,
        "relative_exclude_joints": [],
        "action_feature_names": null,

        "num_inference_steps": 10,
        "time_sampling_beta_alpha": 1.5,
        "time_sampling_beta_beta": 1.0,
        "time_sampling_scale": 0.999,
        "time_sampling_offset": 0.001,
        "min_period": 0.004,
        "max_period": 4.0,

        "rtc_config": null,
        "empty_cameras": 0,
        "tokenizer_max_length": 200,

        "gradient_checkpointing": true,
        "compile_model": false,
        "compile_mode": "max-autotune",

        "freeze_vision_encoder": true,
        "train_expert_only": true,

        "device": "cuda",
        "use_amp": false,
        "use_peft": false,

        "push_to_hub": false,
        "repo_id": "local/Walker_S2_real_pi05_10d",
        "private": null,
        "tags": null,
        "license": null,
        "pretrained_path": "/ubt_IL/model/pi05_base",

        "optimizer_lr": 2.5e-05,
        "optimizer_betas": [
            0.9,
            0.95
        ],
        "optimizer_eps": 1e-08,
        "optimizer_weight_decay": 0.01,
        "optimizer_grad_clip_norm": 1.0,

        "scheduler_warmup_steps": 500,
        "scheduler_decay_steps": 5000,
        "scheduler_decay_lr": 2.5e-06
    },
    "reward_model": null,
    "output_dir": "/ubt_IL/model/Walker_S2_real_pi05_10d",
    "job_name": "Walker_S2_real_pi05_10d",
    "resume": false,
    "seed": 1000,
    "cudnn_deterministic": false,
    "num_workers": 2,
    "batch_size": 4,
    "prefetch_factor": 4,
    "persistent_workers": true,
    "steps": 10000,
    "eval_freq": 1000,
    "log_freq": 50,
    "tolerance_s": 0.0001,
    "save_checkpoint": true,
    "save_freq": 1000,
    "use_policy_training_preset": true,
    "optimizer": null,
    "scheduler": null,
    "eval": {
        "n_episodes": 50,
        "batch_size": 22,
        "use_async_envs": true
    },
    "wandb": {
        "enable": false,
        "disable_artifact": false,
        "project": "lerobot",
        "entity": null,
        "notes": null,
        "run_id": null,
        "mode": null,
        "add_tags": true
    },
    "peft": null,
    "sample_weighting": null,
    "rename_map": {},
    "checkpoint_path": null
}
